{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "ArcanaSovereignAudit",
            "Effect": "Allow",
            "Action": [
                "dynamodb:ListTables",
                "dynamodb:DescribeTable",
                "dynamodb:Scan",
                "dynamodb:GetItem",
                "dynamodb:Query",
                "ec2:DescribeVpcEndpoints"
            ],
            "Resource": "*"
        }
    ]
}
