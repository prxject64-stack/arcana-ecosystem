[Unit]
Description=Arcana Sovereign Vampire Scout Bot
After=network.target

[Service]
User=root
WorkingDirectory=/root/arcana-ecosystem/arcanasnapshotbot-vampire
ExecStart=/root/arcana-ecosystem/arcanasnapshotbot-vampire/venv/bin/python /root/arcana-ecosystem/arcanasnapshotbot-vampire/vampire_scout.py
Restart=always
RestartSec=10
StandardOutput=append:/var/log/arcana-bot.log
StandardError=append:/var/log/arcana-bot.log

[Install]
WantedBy=multi-user.target
